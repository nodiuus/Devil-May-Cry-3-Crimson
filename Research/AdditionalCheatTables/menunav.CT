      <ShowAsSigned>0</ShowAsSigned>
      <VariableType>4 Bytes</VariableType>
      <Address>140D54A10</Address>
    </CheatEntry>
    <CheatEntry>
      <ID>2</ID>
      <Description>"Auto Assemble script"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Game   : dmc3.exe
  Fix    : stable menu input debounce
}

define(address,"dmc3.exe"+32CECA)
define(bytes,66 89 48 04 0F B7 CA)

[ENABLE]
assert(address,bytes)
alloc(newmem,$1000,"dmc3.exe"+32CECA)
alloc(debounce_flag, 1)

label(is_press)
label(code)
label(suppress)
label(return)

newmem:

  // cx = pressed (curr &amp; ~prev)

  test cx,cx
  jnz is_press

  // reset ONLY when fully idle (not every frame of release noise)
  mov byte ptr [debounce_flag],0
  jmp code

is_press:
  cmp byte ptr [debounce_flag],1
  je suppress

  // allow FIRST edge only
  mov byte ptr [debounce_flag],1
  jmp code

suppress:
  xor cx,cx

code:
  mov [rax+04],cx
  movzx ecx,dx
  jmp return

address:
  jmp newmem
  nop 2

return:

[DISABLE]

address:
db bytes

dealloc(newmem)
dealloc(debounce_flag)
</AssemblerScript>
    </CheatEntry>
  </CheatEntries>
