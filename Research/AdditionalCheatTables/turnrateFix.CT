define(address,"dmc3.exe"+1FC5C7)
define(bytes,41 0F BF D9 41 0F BF 08)
define(frameRateMult, Crimson.g_FrameRateTimeMultiplier)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,"dmc3.exe"+1FC5C7)
alloc(fConst60,4)
alloc(scaleConst, 4)

label(code)
label(return)

fConst60:
dd (float)60.0

scaleConst:
dd (float)1.7

newmem:
  // Preserve registers we touch

  push rax
  sub rsp,20            // shadow space for xmm

  movdqu [rsp],xmm0
  movdqu [rsp+10],xmm1

// load FPS

mov rax, frameRateMult
movss xmm0, [rax]

  // MANIPULATE R9W VALUE HERE AND SCALE IT

 movsx eax,r9w          // int -&gt; eax
  cvtsi2ss xmm1,eax      // -&gt; float

  mulss xmm1,xmm0        // scale

  mulss xmm1,[scaleConst] // fasterTurnRate

  cvtss2si eax,xmm1      // back to int

  mov r9w,ax             //  WRITE BACK

// original

  movsx ebx,r9w

  // restore xmm

  movdqu xmm0,[rsp]
  movdqu xmm1,[rsp+10]

  add rsp,20
  pop rax

code:
  movsx ecx,word ptr [r8]
  jmp return

address:
  jmp newmem
  nop 3

return:

[DISABLE]

address:
  db bytes

dealloc(newmem)
dealloc(fConst60)
dealloc(scaleConst)

{
// ORIGINAL CODE - INJECTION POINT: dmc3.exe+1FC5C7

dmc3.exe+1FC5AC: CC              - int 3 
dmc3.exe+1FC5AD: CC              - int 3 
dmc3.exe+1FC5AE: CC              - int 3 
