// ---------- INJECTING HERE ----------
dmc3.exe+E2E2C: F3 0F 5C 84 C7 68 B5 56 00  - subss xmm0,[rdi+rax*8+0056B568]
// ---------- DONE INJECTING  ----------
dmc3.exe+E2E35: F3 0F 11 83 40 06 00 00     - movss [rbx+00000640],xmm0
dmc3.exe+E2E3D: F3 0F 10 83 44 06 00 00     - movss xmm0,[rbx+00000644]
