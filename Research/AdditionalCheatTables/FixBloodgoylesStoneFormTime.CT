    <CheatEntry>
      <ID>1</ID>
      <Description>"FixBloodgoylesStoneFormTime "</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Game   : dmc3.exe
  Version: 
  Date   : 2026-05-13
  Author : berth

  This script does blah blah blah
}

define(address,"dmc3.exe"+E2E2C)
define(frameRateMult, Crimson.g_FrameRateTimeMultiplier)
define(bytes,F3 0F 5C 84 C7 68 B5 56 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,"dmc3.exe"+E2E2C)

label(code)
label(return)

newmem:
dd (float)0.2

code:
  push rdx
  movdqu [rsp], xmm2
  movdqu [rsp+10], xmm1 // preserve registers

  mov rdx, frameRateMult
  movss xmm1, dword ptr [rdx] // load frameratemult
  movss xmm2, dword ptr [rdi+rax*8+0056B568]
  mulss xmm2, xmm1

  subss xmm0, xmm2

  movdqu xmm1, [rsp+10]
  movdqu xmm2, [rsp]
  pop rdx
  jmp return

address:
  jmp code
  nop 4
return:

[DISABLE]

address:
  db bytes
  // subss xmm0,[rdi+rax*8+0056B568]

dealloc(newmem)

{
