    <CheatEntry>
      <ID>2780</ID>
      <Description>"Fix slotTimer[0] frameRateIndependence fix1 -- works"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{ Game   : dmc3.exe
  Version: 
  Date   : 2026-05-10
  Author : berth

  This script does blah blah blah
}

define(address,"dmc3.exe"+1C9A56)
define(frameRateMult, Crimson.g_FrameRateTimeMultiplier)
define(bytes,F3 0F 10 05 42 93 B2 00)

[ENABLE]

assert(address,bytes)
alloc(newmem,$1000,"dmc3.exe"+1C9A56)

label(code)
label(return)

newmem:
dd (float)0.2

code:
  push rax
  movdqu [rsp+10], xmm1 // preserve registers

  mov rax, frameRateMult
  movss xmm1, dword ptr [rax] // load frameratemult

  movss xmm0, xmm1 // patch original instruction

  movdqu xmm1, [rsp+10]
  pop rax
  jmp return

address:
  jmp code
  nop 3
return:

[DISABLE]

address:
  db bytes
  // movss xmm0,[dmc3.exe+CF2DA0]

dealloc(newmem)

{
